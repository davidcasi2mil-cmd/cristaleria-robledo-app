generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  VENDEDOR
}

enum EstadoOrden {
  PENDIENTE
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  nombre    String
  password  String
  rol       Rol      @default(VENDEDOR)
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())
  ordenes   Orden[]

  @@index([email])
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  telefono  String?
  email     String?  @unique
  direccion String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())
  ordenes   Orden[]

  @@index([nombre])
  @@index([email])
}

model Orden {
  id            String      @id @default(cuid())
  numero        Int         @unique @default(autoincrement())
  clienteId     String
  usuarioId     String
  estado        EstadoOrden @default(PENDIENTE)
  notas         String?
  subtotal      Decimal     @db.Decimal(10, 2)
  descuento     Decimal     @db.Decimal(10, 2) @default(0)
  total         Decimal     @db.Decimal(10, 2)
  creadoEn      DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt
  cliente       Cliente     @relation(fields: [clienteId], references: [id])
  usuario       Usuario     @relation(fields: [usuarioId], references: [id])
  lineas        OrdenLinea[]

  @@index([clienteId])
  @@index([usuarioId])
  @@index([estado])
  @@index([creadoEn])
}

model OrdenLinea {
  id          String  @id @default(cuid())
  ordenId     String
  descripcion String
  cantidad    Decimal @db.Decimal(10, 2)
  precioUnit  Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)
  orden       Orden   @relation(fields: [ordenId], references: [id], onDelete: Cascade)

  @@index([ordenId])
}
